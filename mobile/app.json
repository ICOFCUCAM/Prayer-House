{
  "expo": {
    "name": "WANKONG",
    "slug": "wankong-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1128"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wankong.mobile",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "WANKONG needs access to your microphone for recording.",
        "NSCameraUsageDescription": "WANKONG needs camera access to capture artwork and videos.",
        "NSPhotoLibraryUsageDescription": "WANKONG needs photo library access to select artwork and videos.",
        "NSPhotoLibraryAddUsageDescription": "WANKONG needs to save media to your photo library."
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1128",
        "monochromeImage": "./assets/adaptive-icon.png"
      }
    },
    "android": {
      "package": "com.wankong.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1128"
      },
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0A1128",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "WANKONG needs photo library access to select artwork."
        }
      ],
      "expo-av",
      "expo-document-picker"
    ],
    "scheme": "wankong",
    "extra": {
      "eas": {
        "projectId": "wankong-mobile"
      }
    }
  }
}
