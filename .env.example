# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Stripe ────────────────────────────────────────────────────────────────────
# Client-side publishable key (exposed to browser — safe)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Server-side secret (Vercel env only — never expose to browser)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Pre-created recurring price IDs (optional — auto-created if missing)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_PREM_MONTHLY=price_...
STRIPE_PRICE_PREM_YEARLY=price_...

# ── PayPal ────────────────────────────────────────────────────────────────────
# Set PAYPAL_ENV=live for production, leave unset for sandbox
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=AY...
PAYPAL_CLIENT_SECRET=EJ...

# ── M-Pesa / Safaricom Daraja ─────────────────────────────────────────────────
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-lipa-na-mpesa-passkey
MPESA_CALLBACK_URL=https://your-domain.vercel.app/api/mpesa-callback
# MPESA_ENV=sandbox (default) | live

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_DOMAIN=wankong.com

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=BH...   # Exposed to browser (used in useWebPush.ts)
VAPID_PUBLIC_KEY=BH...        # Same value — used server-side in api/send-push.ts
VAPID_PRIVATE_KEY=xxxxxxx...
VAPID_EMAIL=mailto:admin@wankong.com

# ── Supabase service role (server-side only) ───────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Internal API security ─────────────────────────────────────────────────────
# Used by /api/send-email to prevent unauthorized calls
INTERNAL_API_KEY=random-secret-string

# ── App URL ───────────────────────────────────────────────────────────────────
# Used for redirect URLs in payment flows
VITE_APP_URL=https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
